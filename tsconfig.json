{
	"compilerOptions": {
		"target": "ES2025",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"rootDir": "./",
		"outDir": "./dist",
		"types": ["node"],
		"esModuleInterop": true,
		"skipLibCheck": true,
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true
	},
	"include": ["task.ts", "lib.ts"]
}
